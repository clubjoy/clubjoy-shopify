{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="contact page-width page-width--narrow section-{{ section.id }}-padding">

    {%- if section.settings.heading != blank -%}
      <h2 class="title {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="rte">
        {{ section.settings.description }}
      </div>
    {%- endif -%}

    {%- form 'contact', id: 'SmartboxRedemptionForm', class: 'isolate' -%}

      {{ form.errors | default_errors }}

      <!-- ✅ SUCCESS ONLY WHEN URL HAS contact_posted -->
      {% if request.params.contact_posted == 'true' %}
        <h2 class="form-status">
          {{ section.settings.success_message | default: 'Richiesta inviata con successo! Verrai aggiornato a breve.' }}
        </h2>
      {% endif %}

      <!-- ERROR -->
      {% if form.errors %}
        <div class="form__message">
          <h2 class="form-status">
            {{ section.settings.error_message | default: 'Si è verificato un errore. Controlla i campi richiesti.' }}
          </h2>
        </div>
      {% endif %}

      <div class="contact__fields">

        <!-- SMARTBOX CODE -->
        <div class="field">
          <input
            type="text"
            id="SmartboxCode"
            name="contact[Codice Smartbox]"
            class="field__input"
            required
            placeholder="{{ section.settings.code_placeholder | default: 'Inserisci il codice Smartbox' }}"
          >
          <label class="field__label" for="SmartboxCode">
            {{ section.settings.code_label | default: 'Codice Smartbox' }} *
          </label>
        </div>

        <!-- EMAIL -->
        <div class="field">
          <input
            type="email"
            id="SmartboxEmail"
            name="contact[email]"
            class="field__input"
            required
            placeholder="{{ section.settings.email_placeholder | default: 'La tua email' }}"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
          >
          <label class="field__label" for="SmartboxEmail">
            {{ section.settings.email_label | default: 'Email' }} *
          </label>
        </div>

      </div>

      <div class="contact__button">
        <button type="submit" class="button">
          {{ section.settings.button_text | default: 'Riscatta Smartbox' }}
        </button>
      </div>

    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Smartbox Redemption",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Riscatta la tua Smartbox",
      "label": "Titolo"
    },
    {
      "type": "text",
      "id": "description",
      "default": "Inserisci il codice della tua Smartbox per ricevere una gift card.",
      "label": "Descrizione"
    },
    {
      "type": "text",
      "id": "code_label",
      "default": "Codice Smartbox",
      "label": "Label codice"
    },
    {
      "type": "text",
      "id": "code_placeholder",
      "default": "Inserisci il codice Smartbox",
      "label": "Placeholder codice"
    },
    {
      "type": "text",
      "id": "email_label",
      "default": "Email",
      "label": "Label email"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "default": "La tua email",
      "label": "Placeholder email"
    },
    {
      "type": "text",
      "id": "button_text",
      "default": "Riscatta Smartbox",
      "label": "Testo bottone"
    },
    {
      "type": "text",
      "id": "success_message",
      "default": "Richiesta inviata con successo!",
      "label": "Messaggio successo"
    },
    {
      "type": "text",
      "id": "error_message",
      "default": "Si è verificato un errore. Controlla i campi richiesti.",
      "label": "Messaggio errore"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36,
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36,
      "label": "Padding bottom"
    }
  ],
  "presets": [
    {
      "name": "Smartbox Redemption"
    }
  ]
}
{% endschema %}