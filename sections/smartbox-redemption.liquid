{{ 'smartbox-redemption.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="smartbox-redemption page-width page-width--narrow section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank -%}
      <h2 class="title title-wrapper--no-top-margin inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="smartbox-redemption__description rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.description }}
      </div>
    {%- endif -%}

    {%- liquid
      assign form_class = 'smartbox-redemption__form isolate'
      if settings.animations_reveal_on_scroll
        assign form_class = 'smartbox-redemption__form isolate scroll-trigger animate--slide-in'
      endif
    -%}

    {%- form 'contact', id: 'SmartboxRedemptionForm', class: form_class -%}
      {{ form.errors | default_errors }}

      {%- if form.posted_successfully? -%}
        <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
          {{- 'icon-success.svg' | inline_asset_content -}}
          {{ section.settings.success_message | default: 'Richiesta inviata con successo! Verrai contattato a breve.' }}
        </h2>
      {%- elsif form.errors -%}
        <div class="form__message">
          <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
            {{- 'icon-error.svg' | inline_asset_content -}}
            {{ section.settings.error_message | default: 'Si è verificato un errore. Controlla i campi richiesti.' }}
          </h2>
        </div>
      {%- endif -%}

      <div class="smartbox-redemption__fields">
        <div class="field">
          <input
            class="field__input"
            type="text"
            id="SmartboxCode"
            name="contact[Codice Smartbox]"
            value="{{ form.smartbox_code }}"
            required
            placeholder="{{ section.settings.code_placeholder | default: 'Inserisci il codice Smartbox' }}"
            autocomplete="off"
          >
          <label class="field__label" for="SmartboxCode">
            {{ section.settings.code_label | default: 'Codice Smartbox' }}
            <span aria-hidden="true">*</span>
          </label>
        </div>

        <div class="field field--with-error">
          <input
            autocomplete="email"
            type="email"
            id="SmartboxEmail"
            class="field__input"
            name="contact[email]"
            value="{{ form.email }}"
            spellcheck="false"
            autocapitalize="off"
            aria-required="true"
            required
            placeholder="{{ section.settings.email_placeholder | default: 'La tua email' }}"
            {% if form.errors contains 'email' %}
              aria-invalid="true"
              aria-describedby="SmartboxEmail-error"
            {% endif %}
          >
          <label class="field__label" for="SmartboxEmail">
            {{ section.settings.email_label | default: 'Email' }}
            <span aria-hidden="true">*</span>
          </label>

          {%- if form.errors contains 'email' -%}
            <small class="contact__field-error" id="SmartboxEmail-error">
              <span class="visually-hidden">Errore</span>
              <span class="form__message">
                <span class="svg-wrapper">
                  {{- 'icon-error.svg' | inline_asset_content -}}
                </span>
                Email {{ form.errors.messages.email }}
              </span>
            </small>
          {%- endif -%}
        </div>
      </div>

      <div class="smartbox-redemption__button">
        <button type="submit" class="button">
          {{ section.settings.button_text | default: 'Riscatta Smartbox' }}
        </button>
      </div>
    {%- endform -%}
  </div>
</div>


{% schema %}
{
  "name": "Smartbox Redemption",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Riscatta la tua Smartbox",
      "label": "Titolo"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        },
        {
          "value": "hxl",
          "label": "Extra Large"
        },
        {
          "value": "hxxl",
          "label": "XXL"
        }
      ],
      "default": "h1",
      "label": "Dimensione titolo"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Descrizione",
      "default": "<p>Inserisci il codice della tua Smartbox per ricevere una gift card da utilizzare nel nostro store.</p>"
    },
    {
      "type": "text",
      "id": "code_label",
      "label": "Label campo codice",
      "default": "Codice Smartbox"
    },
    {
      "type": "text",
      "id": "code_placeholder",
      "label": "Placeholder campo codice",
      "default": "Inserisci il codice Smartbox"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Label campo email",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Placeholder campo email",
      "default": "La tua email"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Testo bottone",
      "default": "Riscatta Smartbox"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Messaggio successo",
      "default": "Richiesta inviata con successo! Verrai contattato a breve."
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "Messaggio errore",
      "default": "Si è verificato un errore. Controlla i campi richiesti."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Smartbox Redemption"
    }
  ]
}
{% endschema %}
