{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .smartbox-success {
    display: none;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="contact page-width page-width--narrow section-{{ section.id }}-padding">

    {%- if section.settings.heading != blank -%}
      <h2 class="title {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="rte">
        {{ section.settings.description }}
      </div>
    {%- endif -%}

    <form method="post" action="/contact" id="SmartboxRedemptionForm">
      <input type="hidden" name="form_type" value="contact">
      <input type="hidden" name="utf8" value="✓">

      <div id="FormSuccess" class="smartbox-success">
        <h2 class="form-status">
          {{ section.settings.success_message | default: 'Richiesta inviata con successo! Verrai aggiornato a breve.' }}
        </h2>
      </div>

      <div id="FormFields" class="contact__fields">

        <div class="field">
          <input
            type="text"
            name="contact[Codice Smartbox]"
            class="field__input"
            required
            placeholder="{{ section.settings.code_placeholder | default: 'Inserisci il codice Smartbox' }}"
          >
          <label class="field__label">
            {{ section.settings.code_label | default: 'Codice Smartbox' }} *
          </label>
        </div>

        <div class="field">
          <input
            type="email"
            name="contact[email]"
            class="field__input"
            required
            placeholder="{{ section.settings.email_placeholder | default: 'La tua email' }}"
          >
          <label class="field__label">
            {{ section.settings.email_label | default: 'Email' }} *
          </label>
        </div>

      </div>

      <div class="contact__button">
        <button type="button" class="button" id="SmartboxSubmitBtn">
          {{ section.settings.button_text | default: 'Riscatta Smartbox' }}
        </button>
      </div>

    </form>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const form = document.getElementById("SmartboxRedemptionForm");
  const success = document.getElementById("FormSuccess");
  const fields = document.getElementById("FormFields");
  const button = document.getElementById("SmartboxSubmitBtn");

  if (!form || !button) return;

  button.addEventListener("click", function () {
    const code = form.querySelector('input[name="contact[Codice Smartbox]"]');
    const email = form.querySelector('input[name="contact[email]"]');

    if (!code.value.trim() || !email.value.trim()) {
      alert("Per favore compila tutti i campi.");
      return;
    }

    const data = new FormData(form);

    fetch("/contact", {
      method: "POST",
      body: data,
      redirect: "manual"
    })
    .then(function (response) {
      if (response.ok || response.type === "opaqueredirect") {
        fields.style.display = "none";
        success.style.display = "block";
      } else {
        alert("Si è verificato un errore. Riprova.");
      }
    })
    .catch(function () {
      alert("Si è verificato un errore. Riprova.");
    });
  });
});
</script>

{% schema %}
{
  "name": "Smartbox Redemption",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Goditi la tua Smartbox",
      "label": "Titolo"
    },
    {
      "type": "text",
      "id": "description",
      "default": "Inserisci il codice della tua Smartbox per ricevere una gift card.",
      "label": "Descrizione"
    },
    {
      "type": "text",
      "id": "code_label",
      "default": "Codice Smartbox",
      "label": "Label codice"
    },
    {
      "type": "text",
      "id": "code_placeholder",
      "default": "Inserisci il codice Smartbox",
      "label": "Placeholder codice"
    },
    {
      "type": "text",
      "id": "email_label",
      "default": "Email",
      "label": "Label email"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "default": "La tua email",
      "label": "Placeholder email"
    },
    {
      "type": "text",
      "id": "button_text",
      "default": "Riscatta Smartbox",
      "label": "Testo bottone"
    },
    {
      "type": "text",
      "id": "success_message",
      "default": "Richiesta inviata con successo!",
      "label": "Messaggio successo"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36,
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36,
      "label": "Padding bottom"
    }
  ],
  "presets": [
    {
      "name": "Smartbox Redemption"
    }
  ]
}
{% endschema %}