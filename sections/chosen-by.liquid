{{ 'chosen-by.css' | asset_url | stylesheet_tag }}

<div class="page-width">
  {% if section.settings.title != blank %}
    <h2 class="chosen-by-title">{{ section.settings.title }}</h2>
  {% endif %}

  {% if section.settings.subtitle != blank %}
    <p class="chosen-by-subtitle">{{ section.settings.subtitle }}</p>
  {% endif %}

  <div class="chosen-by-section" data-ga-name="chosen_by_section">
    <div class="chosen-by-logos-wrapper">
      <div class="chosen-by-logos-scroller js-chosen-by-scroller">
        <div class="chosen-by-logos-list-wrapper js-chosen-by-list-wrapper">
          <div class="chosen-by-logos-list js-chosen-by-list">

            {% assign logos = 'cafezal.webp,caffevergnano.webp,guarneri.webp,dream-factory.webp' | split: ',' %}
            {% assign company_urls = 'https://www.clubjoy.it/search?q=cafezal&options%5Bprefix%5D=last,https://www.clubjoy.it/search?q=vergano&options%5Bprefix%5D=last,https://www.clubjoy.it/search?q=guarneri&options%5Bprefix%5D=last,https://www.clubjoy.it/search?q=dream+factory&options%5Bprefix%5D=last' | split: ',' %}

            {% for i in (0..3) %}
              {% if logos[i] != blank %}
                <div class="logo-item">
                  {% if company_urls[i] != blank %}
                    <a href="{{ company_urls[i] }}" target="_blank" rel="noopener" class="logo-link">
                      <img
                        src="{{ logos[i] | asset_url }}"
                        alt=""
                        loading="lazy"
                        class="logo-image"
                        onerror="this.closest('.logo-item').remove();"
                      >
                    </a>
                  {% else %}
                    <img
                      src="{{ logos[i] | asset_url }}"
                      alt=""
                      loading="lazy"
                      class="logo-image"
                      onerror="this.closest('.logo-item').remove();"
                    >
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}

          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const wrapper = document.querySelector(".js-chosen-by-list-wrapper");
  const list = document.querySelector(".js-chosen-by-list");
  const container = document.querySelector(".js-chosen-by-scroller");

  if (!wrapper || !list || !container) return;

  setTimeout(() => {
    const fullWidth = list.offsetWidth;

    if (!fullWidth) return;

    const clone1 = list.cloneNode(true);
    const clone2 = list.cloneNode(true);

    wrapper.appendChild(clone1);
    wrapper.appendChild(clone2);

    wrapper.style.setProperty('--chosen-by-scroll-distance', `-${fullWidth}px`);

    let isDragging = false;
    let startX = 0;
    let currentTranslateX = 0;
    let animationPosition = 0;
    let userInteractionTimeout;
    let isUserInteracting = false;

    function getCurrentAnimationPosition() {
      const computedStyle = getComputedStyle(wrapper);
      const matrix = computedStyle.transform;

      if (matrix === 'none') return 0;

      const values = matrix.split('(')[1].split(')')[0].split(',');
      return parseFloat(values[4]) || 0;
    }

    function startManualControl(clientX) {
      isDragging = true;
      isUserInteracting = true;
      startX = clientX;

      animationPosition = getCurrentAnimationPosition();
      currentTranslateX = animationPosition;

      wrapper.classList.add('user-interacting');
      container.classList.add('dragging');

      clearTimeout(userInteractionTimeout);
    }

    function handleManualMove(clientX) {
      if (!isDragging) return;

      const deltaX = clientX - startX;
      currentTranslateX = animationPosition + deltaX;

      wrapper.style.transform = `translateX(${currentTranslateX}px)`;
    }

    function endManualControl() {
      if (!isDragging) return;

      isDragging = false;
      container.classList.remove('dragging');

      userInteractionTimeout = setTimeout(() => {
        isUserInteracting = false;
        wrapper.classList.remove('user-interacting');

        const currentPos = getCurrentAnimationPosition();
        const remainingDistance = fullWidth + currentPos;
        const totalDistance = fullWidth;
        const remainingRatio = remainingDistance / totalDistance;

        if (remainingRatio > 0) {
          wrapper.style.animation = `chosen-by-scroll ${40 * remainingRatio}s linear infinite`;
          wrapper.style.animationDelay = '0s';
        }
      }, 2000);
    }

    container.addEventListener('mousedown', (e) => {
      e.preventDefault();
      startManualControl(e.clientX);
    });

    document.addEventListener('mousemove', (e) => {
      handleManualMove(e.clientX);
    });

    document.addEventListener('mouseup', endManualControl);

    container.addEventListener('touchstart', (e) => {
      e.preventDefault();
      const touch = e.touches[0];
      startManualControl(touch.clientX);
    }, { passive: false });

    container.addEventListener('touchmove', (e) => {
      e.preventDefault();
      const touch = e.touches[0];
      handleManualMove(touch.clientX);
    }, { passive: false });

    container.addEventListener('touchend', endManualControl);
    container.addEventListener('touchcancel', endManualControl);

    container.addEventListener('selectstart', (e) => {
      if (isDragging) e.preventDefault();
    });

    container.addEventListener('mouseenter', () => {
      if (!isUserInteracting) {
        wrapper.classList.add('manual-control');
      }
    });

    container.addEventListener('mouseleave', () => {
      if (!isUserInteracting) {
        wrapper.classList.remove('manual-control');
      }
    });
  }, 300);
});
</script>

{% schema %}
{
  "name": "Chosen By Logos",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Scelto da"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "select",
      "id": "logos_per_row",
      "label": "Logos per row",
      "options": [
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        },
        {
          "value": "5",
          "label": "5"
        },
        {
          "value": "6",
          "label": "6"
        }
      ],
      "default": "4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Chosen By Logos"
    }
  ]
}
{% endschema %}